# Lemon Squeezy checkout URL for the Pro plan
# Get this from your Lemon Squeezy dashboard → Products → Share → Checkout URL
VITE_LS_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/your-variant-id

# Formspree endpoint for the contact form
# Create a free form at https://formspree.io → copy the endpoint URL
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
