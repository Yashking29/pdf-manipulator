ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# AI provider: 'anthropic' | 'gemini' | 'both'
# 'both' uses Anthropic as primary and falls back to Gemini if Anthropic fails
AI_PROVIDER=anthropic

PORT=3001
# Your production domain (used for canonical URLs and OG tags in share pages)
SITE_URL=https://briefwise.online
# Comma-separated list of allowed CORS origins (defaults to localhost:5173/5174 in dev)
# ALLOWED_ORIGINS=https://briefwise.online
